APP_NAME="Damas Cleaning"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL en tu Mac: `docker compose up -d mysql` luego `php artisan migrate` (host 127.0.0.1, no "mysql").
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=sail
DB_PASSWORD=password
#
# Sin MySQL local: SQLite
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite
#
# Dentro del contenedor de la app (sail artisan): podrías usar DB_HOST=mysql.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Panel admin (/admin): usuario «propietario» creado con php artisan db:seed (AdminUserSeeder).
# Puede crear empleados con rol staff en Equipo → Nuevo usuario.
ADMIN_EMAIL=admin@damascleaning.com
ADMIN_PASSWORD=changeme
ADMIN_NAME="Administrador"

# Logo / favicon / PDF (path under public/). Default: images/damas-logo.png
# BRAND_LOGO_PATH=images/damas-logo.png
# INVOICE_COMPANY_NAME="DAMAS Cleaning Home Services"
# INVOICE_COMPANY_ADDRESS="717 Kestrel Dr. Loganville, GA 30052"
# INVOICE_COMPANY_PHONES="678-525-6816 / 678-382-7724"
# INVOICE_TERMS="Due on receipt"
# INVOICE_PAYMENT_METHOD="Cash only"
# INVOICE_NUMBER_PREFIX=
# INVOICE_NUMBER_PAD=8

VITE_APP_NAME="${APP_NAME}"
